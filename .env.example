# Open Brain - Standalone Environment Configuration

# LLM Provider (required for thought classification)
ANTHROPIC_API_KEY=sk-ant-...
LLM_PROVIDER=anthropic
AI_MODEL=claude-haiku-4-5-20251001

# Embeddings (Ollama all-minilm, pulled automatically)
# OLLAMA_URL and EMBEDDING_MODEL are set in docker-compose.yml

# API Key Authentication (optional, enables Bearer token auth)
# If set, all API calls require Authorization: Bearer <key>
# If empty, no auth (local dev mode)
OPEN_BRAIN_API_KEY=

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
