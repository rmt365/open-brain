# Open Brain Instance Configuration
# Copy this file and fill in values: cp .env.template robin-brain.env

# Instance identity
INSTANCE_NAME=
SUBDOMAIN=

# API keys
ANTHROPIC_API_KEY=
OPEN_BRAIN_API_KEY=

# Backup (Wasabi S3)
ENABLE_LITESTREAM=true
WASABI_ENDPOINT=https://s3.wasabisys.com
WASABI_REGION=us-east-1
WASABI_BUCKET=
WASABI_ACCESS_KEY_ID=
WASABI_SECRET_ACCESS_KEY=

# MCP auth
# Token for URL-based auth (generate with: python3 -c "import secrets; print(secrets.token_urlsafe(24))")
MCP_URL_TOKEN=
# Basic auth (generate with: htpasswd -nbB brain "$OPEN_BRAIN_API_KEY" | sed 's/\$/\$\$/g')
MCP_AUTH_USERS=

# Telegram (optional — enable with: docker compose --profile telegram up -d)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
